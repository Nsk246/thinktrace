# ThinkTrace Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
APP_SECRET_KEY=generate-with-python-secrets-token-hex-32
APP_ENV=development

# ── Database ──────────────────────────────────────────────────
# Development: SQLite (default)
DATABASE_URL=sqlite:///./thinktrace.db
# Production: PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/thinktrace

# ── Redis (Upstash) ───────────────────────────────────────────
REDIS_URL=rediss://default:your-password@your-host.upstash.io:6379

# ── AI Observability (LangSmith) ──────────────────────────────
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=thinktrace

# ── Vector Database (Pinecone) ────────────────────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=thinktrace

# ── Knowledge Graph (Neo4j Aura) ──────────────────────────────
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Fact Checking APIs ────────────────────────────────────────
SERPER_API_KEY=your-serper-key
NEWS_API_KEY=your-newsapi-key

# ── Offline Mode (do not change) ─────────────────────────────
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1
HF_DATASETS_OFFLINE=1
