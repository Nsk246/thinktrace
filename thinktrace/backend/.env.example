# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# LangSmith observability
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=thinktrace

# Pinecone vector DB
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=thinktrace

# Redis (Upstash free tier)
REDIS_URL=redis://default:your_upstash_password@your_upstash_url:6379

# App config
APP_SECRET_KEY=supersecretkey_changeme_in_prod
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (SQLite for dev)
DATABASE_URL=sqlite:///./thinktrace.db

# Neo4j (local for now)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password